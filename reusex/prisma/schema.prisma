generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Listing {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float

  imageUrl    String?

  createdAt   DateTime @default(now())

  sellerId String
  seller   User @relation(fields: [sellerId], references: [id])
}